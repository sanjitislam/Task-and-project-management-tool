RewriteEngine On
RewriteBase /task_management/

Options -Indexes

# Block sensitive application folders/files from direct browser access.
RewriteRule ^(config|core|controllers|models|helpers|_database)/ - [F,L]
RewriteRule (^|/)\.git/ - [F,L]

<FilesMatch "\.(sql|zip|bak|env|ini|log)$">
    Require all denied
</FilesMatch>

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ index.php?url=$1 [QSA,L]
